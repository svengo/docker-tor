# Tor Configuration
NICKNAME=ididnteditheconfig
CONTACTINFO=Random Person <nobody AT example dot com>
HASHEDCONTROLPASSWORD=16:your_hashed_password

# Network Configuration
ORPORT=9001
DIRPORT=9030
CONTROLPORT=9051

# Security Settings
EXITPOLICY=reject *:*

# Additional Configuration (SOCKS_PORT requires manual port mapping in docker-compose.yml if host access is needed)
SOCKS_PORT=
SOCKS_POLICY=
MYFAMILY=
ADDRESS=
RELAY_BANDWIDTH_RATE=
RELAY_BANDWIDTH_BURST=

# Generate hashed password with:
# docker compose exec daemon tor --hash-password "your_password"
