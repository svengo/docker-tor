# Tor Configuration
NICKNAME=ididnteditheconfig
CONTACTINFO=Random Person <nobody AT example dot com>
HASHEDCONTROLPASSWORD=16:your_hashed_password

# Network Configuration
ORPORT=9001
DIRPORT=9030
CONTROLPORT=9051
SOCKS_PORT=9050

# Security Settings
EXITPOLICY=reject *:*

# Additional Configuration
MYFAMILY=
ADDRESS=
RELAY_BANDWIDTH_RATE=
RELAY_BANDWIDTH_BURST=

# Generate hashed password with:
# docker compose exec tor tor --hash-password "your_password"
